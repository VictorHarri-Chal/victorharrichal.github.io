        <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 rounded-full text-sm">Tailwind CSS</span>
        <span class="px-3 py-1 bg-cyan-500/20 text-cyan-300 rounded-full text-sm">Hotwire (Turbo + Stimulus)</span>
        <span class="px-3 py-1 bg-green-500/20 text-green-300 rounded-full text-sm">Leaflet.js + OpenStreetMap</span>
        <span class="px-3 py-1 bg-orange-500/20 text-orange-300 rounded-full text-sm">Chart.js</span>
